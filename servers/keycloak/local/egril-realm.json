{
  "realm": "egril",
  "enabled": true,
  "displayName": "Egril",
  "displayNameHtml": "<b>Egril</b>",
  "loginTheme": "egril",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "registrationEmailAsUsername": true,
  "rememberMe": true,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "sslRequired": "none",
  "internationalizationEnabled": true,
  "supportedLocales": [
    "en",
    "de",
    "es",
    "fr",
    "it"
  ],
  "defaultLocale": "en",
  "clients": [
    {
      "clientId": "defender-of-egril",
      "name": "Defender of Egril",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:8080/*",
        "http://localhost:8081/*",
        "http://localhost:8082/*",
        "http://localhost:8888/*",
        "http://localhost:10001/callback",
        "egril://callback"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "http://localhost:8081",
        "http://localhost:8082",
        "http://localhost:8888",
        "+"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:8080/*##http://localhost:8081/*##http://localhost:8082/*##http://localhost:8888/*##http://localhost:10001/*##+##egril://callback",
        "backchannel.logout.url": "http://backend:8080/api/backchannel-logout",
        "backchannel.logout.session.required": "false"
      }
    },
    {
      "clientId": "defender-of-egril-desktop",
      "name": "Defender of Egril Desktop",
      "description": "Public client for the desktop app. Uses Device Authorization Grant (RFC 8628) — no browser redirect, no PKCE.",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "consentRequired": false,
      "protocol": "openid-connect",
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "true",
        "post.logout.redirect.uris": "egril://callback"
      },
      "protocolMappers": [
        {
          "name": "defender-of-egril-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "defender-of-egril",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "defender-of-egril-cli",
      "name": "Defender of Egril CLI",
      "description": "Public client for developer scripts and API testing. Allows Resource Owner Password Credentials flow.",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "attributes": {}
    }
  ],
  "users": [
    {
      "username": "tester@test.org",
      "email": "tester@test.org",
      "firstName": "Test",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "test",
          "temporary": false
        }
      ]
    }
  ],
  "roles": {
    "client": {
      "defender-of-egril": [
        {
          "name": "community_admin",
          "description": "Allows listing and deleting community maps and levels via the admin API"
        }
      ]
    }
  }
}
