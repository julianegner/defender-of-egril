      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-app" },
          "format": "time_series",
          "rawSql": "SELECT date_trunc('day', created_at) AS time, COUNT(*) AS \"Events\" FROM events WHERE created_at >= NOW() - INTERVAL '90 days' GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
